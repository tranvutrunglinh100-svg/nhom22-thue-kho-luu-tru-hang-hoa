{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "WareFlow — Flask Run",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "args": ["run", "--debug", "--port", "5000"],
      "jinja": true,
      "justMyCode": true,
      "env": {
        "FLASK_APP": "run.py",
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "WareFlow — Seed Database",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/seed.py",
      "console": "integratedTerminal"
    }
  ]
}
